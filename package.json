{
  "$schema": "node_modules/albatros/schema.json",
  "name": "ru.dkorchemnyi.topomatic360.bcf",
  "displayName": "BCF Manager",
  "description": "BCF-плагин для Topomatic 360: импорт и экспорт BCF 2.0/2.1/3.0, менеджер замечаний и редактор замечаний на русском языке.",
  "version": "0.4.0",
  "main": "src/index.ts",
  "sdk": "^1.4.0",
  "apx": true,
  "scripts": {
    "serve": "node node_modules/albatros/albatros-cli.cjs serve",
    "build": "node node_modules/albatros/albatros-cli.cjs build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "keywords": [
    "category::coordination",
    "bcf",
    "topomatic360"
  ],
  "author": {
    "name": "Dmitrii Korchemnyi"
  },
  "license": "MIT",
  "devDependencies": {
    "albatros": "^1.4.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "xmlbuilder2": "^3.1.1"
  },
  "albatros": {
    "actions": {
      "bcf_manager": {
        "label": "Менеджер BCF",
        "cmd": "bcf_open_manager"
      },
      "bcf_import": {
        "label": "Импорт BCF",
        "cmd": "bcf_import"
      },
      "bcf_export": {
        "label": "Экспорт BCF",
        "cmd": "bcf_export"
      },
      "bcf_create": {
        "label": "Создать замечание BCF",
        "cmd": "bcf_create_topic"
      },
      "bcf_about": {
        "label": "О плагине BCF",
        "cmd": "bcf_about"
      }
    },
    "menu": [
      {
        "label": "BCF",
        "submenu": [
          {
            "action": "bcf_manager"
          },
          {
            "action": "bcf_import"
          },
          {
            "action": "bcf_export"
          },
          {
            "tag": "s"
          },
          {
            "action": "bcf_create"
          },
          {
            "action": "bcf_about"
          }
        ]
      }
    ],
    "pages": [
      {
        "tag": "bcf_page",
        "label": "BCF",
        "groups": [
          {
            "tag": "bcf_main",
            "label": "Замечания",
            "items": [
              {
                "tag": "b",
                "action": "bcf_manager"
              },
              {
                "tag": "b",
                "action": "bcf_import"
              },
              {
                "tag": "b",
                "action": "bcf_export"
              },
              {
                "tag": "b",
                "action": "bcf_create"
              }
            ]
          }
        ]
      }
    ],
    "viewsContainers": {
      "bcf_tools": {
        "label": "BCF",
        "icon": "build",
        "container": "left"
      }
    },
    "views": {
      "bcf_topics": {
        "label": "Замечания",
        "type": "treeview",
        "cmd": "bcf_topic_tree",
        "container": "bcf_tools"
      }
    },
    "statusbar": {
      "bcf_status": {
        "alignment": "left",
        "name": "BCF",
        "cmd": "bcf_about"
      }
    },
    "context": {
      "projectExpolorer:context:layer": [
        {
          "action": "bcf_create"
        },
        {
          "action": "bcf_manager"
        }
      ]
    },
    "broadcasts": {
      "ss:changed": "bcf_about"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dmitrii-korchemnyi/dkorchemnyi.topomatic360.bcf.git"
  },
  "homepage": "https://dmitrii-korchemnyi.github.io/dkorchemnyi.topomatic360.bcf/"
}